  '能否', '是否', '有没有', '是不是', '能不能', '会不会',
  // 否定/困难
  '不行', '无法', '不能', '不会', '不懂', '不明白', '不清楚', '不知道',
  // 问题/故障
  '失败', '报错', '错误', '问题', '故障', '异常', '出错', '坏了',
  // 具体操作困难
  '登不上', '连不上', '打不开', '找不到', '看不到', '收不到', '发不了', '用不了',
  '怎么弄', '怎么搞', '咋弄', '咋搞', '怎么办',
  // 性能问题
  '卡', '卡顿', '闪退', '崩溃', '死机', '慢', '延迟',
  // 费用/账户
  '退款', '续费', '到期', '过期', '扣费', '账单', '收费',
  // 操作类
  '安装', '下载', '更新', '升级', '配置', '设置', '开通',
  '账号', '密码', '登录', '注册', '绑定', '解绑', '验证',
  // 渠道
  '客服', '人工', '投诉', '建议', '反馈', '举报',
]

// AI意图识别模型（用于判断消息是否为提问，建议用快速廉价模型）
export const intentModel = 'deepseek-v4-flash'
